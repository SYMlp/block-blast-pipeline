{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "BlockBlastVariantConfig",
  "type": "object",
  "required": ["variant_id", "board", "spawn", "scoring", "juice"],
  "properties": {
    "variant_id":   { "type": "string" },
    "variant_name": { "type": "string" },
    "intent": {
      "type": "object",
      "description": "意图层:一句人话假设 + 该变体要命中的代理指标带。harness/verify 拿它和 last-run.json 的实测代理逐条比对——这是'人类感受↔程序参数'的双向锚。",
      "required": ["hypothesis", "targets"],
      "properties": {
        "hypothesis": { "type": "string", "description": "人话:这个变体想验证什么感受假设" },
        "expect": { "type": "string", "enum": ["PROMOTE", "REJECT"], "description": "这个变体被设计成的预期裁决:PROMOTE=应当全部命中带、REJECT=故意越带的反例(如 relaxed)。CI 用它做裁决回归守护:实测裁决≠expect 即门禁回归,挂 CI。" },
        "targets": {
          "type": "array",
          "description": "每条 = 一个可测代理 + 期望落在的双边带 [地板, 天花板](null=该侧不设限)",
          "items": {
            "type": "object",
            "required": ["proxy", "band", "represents"],
            "properties": {
              "proxy": { "type": "string", "enum": ["rescueRate", "clearRate", "rewardEntropy", "stepsP90", "stepsMedian", "avgEndOccupancy", "avgScore", "avgSteps", "avgLines"] },
              "band": { "type": "array", "items": { "type": ["number", "null"] }, "minItems": 2, "maxItems": 2 },
              "represents": { "type": "string", "description": "这个代理代表哪种人类感受" }
            }
          }
        }
      }
    },
    "board": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width":  { "type": "integer", "minimum": 6, "maximum": 12, "default": 8 },
        "height": { "type": "integer", "minimum": 6, "maximum": 12, "default": 8 }
      }
    },
    "spawn": {
      "type": "object",
      "properties": {
        "density":       { "type": "number", "minimum": 0.2, "maximum": 0.9, "default": 0.5 },
        "shape_set":     { "type": "string", "enum": ["minimal", "standard", "extended"], "default": "standard" },
        "preview_count": { "type": "integer", "minimum": 1, "maximum": 5, "default": 3 },
        "big_piece_weight_mult": { "type": "number", "default": 1.0 }
      }
    },
    "scoring": {
      "type": "object",
      "properties": {
        "placement_per_cell": { "type": "integer", "default": 1 },
        "clear_base_factor":  { "type": "number", "default": 5,
          "description": "消除 r 行得分 = factor*r*(r+1)/2 累进（1010! 二次曲线）" },
        "combo_curve": { "type": "string", "enum": ["linear", "quadratic", "stepped"], "default": "stepped" }
      }
    },
    "difficulty": {
      "type": "object",
      "properties": {
        "dda_enabled":     { "type": "boolean", "default": true, "description": "true=按棋盘占用率动态调整发片权重；false=静态权重" },
        "dda_high_occupancy":  { "type": "number", "default": 0.75, "description": "占用率超过此阈值→偏发小片救援" },
        "dda_low_occupancy":   { "type": "number", "default": 0.35, "description": "占用率低于此阈值→偏发大片挑战" }
      }
    },
    "juice": {
      "type": "object",
      "description": "手感/渲染层参数（被 renderer/CanvasRenderer.js 读取，不影响玩法逻辑）",
      "properties": {
        "line_clear_trauma":  { "type": "number", "default": 0.3 },
        "hit_stop_ms":        { "type": "integer", "default": 50 },
        "particles_per_cell": { "type": "integer", "default": 10 },
        "flash_alpha":        { "type": "number", "default": 0.3 }
      }
    }
  }
}
