{
  "name": "block-blast-pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Spec-driven A/B variant generation pipeline for casual games, demoed on a Block Blast clone.",
  "scripts": {
    "test": "vitest run harness/unit",
    "test:watch": "vitest harness/unit",
    "typecheck": "tsc --noEmit",
    "sim": "node harness/sim/headless-sim.js",
    "sim:all": "node harness/sim/headless-sim.js --games 200",
    "verify": "node harness/verify/check-targets.js",
    "verify:ci": "node harness/verify/check-targets.js --check-expectations"
  },
  "devDependencies": {
    "fast-check": "^3.23.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  }
}
